{
  "name": "domain-alive",
  "version": "0.1.19",
  "description": "A Node.js library for checking if an FQDN (Fully Qualified Domain Name) is alive or not, uses a combination techniques of `NS` records, WHOIS/RDAP lookups, `A/AAAA` records",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SukkaW/domain-alive.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "lint": "eslint --format=sukka .",
    "build": "bunchee --no-sourcemap",
    "node": "node --require=@swc-node/register",
    "prerelease": "pnpm run lint && pnpm run build",
    "release": "bumpp -r --all --commit \"release: %s\" --tag \"%s\""
  },
  "keywords": [
    "DNS",
    "Domain",
    "FQDN",
    "Whois",
    "RDAP"
  ],
  "author": "SukkaW <https://skk.moe>",
  "license": "MIT",
  "dependencies": {
    "debug": "4.4.1",
    "foxts": "^5.4.0",
    "tldts": "^7.0.28"
  },
  "devDependencies": {
    "@eslint-sukka/node": "^8.9.2",
    "@swc-node/register": "^1.11.1",
    "@types/debug": "^4.1.13",
    "@types/dns-packet": "^5.6.5",
    "@types/node": "^24.12.2",
    "bumpp": "^10.4.1",
    "bunchee": "^6.10.0",
    "dohdec": "^8.0.0",
    "eslint": "^10.2.0",
    "eslint-config-sukka": "^8.9.2",
    "eslint-formatter-sukka": "^8.9.2",
    "http2-wrapper": "^2.2.1",
    "typescript": "^6.0.2",
    "whoiser": "2.0.0-beta.8"
  },
  "packageManager": "pnpm@10.33.0"
}
